#!/bin/bash
# muppet-launch — Start a muppet session on a remote host
#
# Usage: muppet-launch <host> <name> <prompt-file> [workdir]
#   host:        SSH host alias (e.g., krobot, cssp)
#   name:        Session name (becomes tmux session "muppet-<name>")
#   prompt-file: Path to the prompt file (local path, will be scp'd to host)
#   workdir:     Optional working directory on host (default: ~)
#
# Examples:
#   muppet-launch krobot cli prompts/krobot-cli.txt ~/github.com/krobot
#   muppet-launch cssp cssp-ui prompts/cssp-ui.txt ~/capstone-cssp

set -e

HOST="$1"
NAME="$2"
PROMPT_FILE="$3"
WORKDIR="${4:-$HOME}"
SESSION="muppet-${NAME}"

if [ -z "$HOST" ] || [ -z "$NAME" ] || [ -z "$PROMPT_FILE" ]; then
    echo "Usage: muppet-launch <host> <name> <prompt-file> [workdir]"
    echo ""
    echo "  host:        SSH host alias (e.g., krobot, cssp)"
    echo "  name:        Session name (becomes tmux session 'muppet-<name>')"
    echo "  prompt-file: Local path to prompt file"
    echo "  workdir:     Working directory on host (default: ~)"
    echo ""
    echo "Examples:"
    echo "  muppet-launch krobot cli prompts/krobot-cli.txt ~/github.com/krobot"
    echo "  muppet-launch cssp cssp-ui prompts/cssp-ui.txt ~/capstone-cssp"
    exit 1
fi

if [ ! -f "$PROMPT_FILE" ]; then
    echo "Error: Prompt file not found: $PROMPT_FILE"
    exit 1
fi

IS_LOCAL=false
if [ "$HOST" = "local" ] || [ "$HOST" = "localhost" ]; then
    IS_LOCAL=true
fi

if [ "$IS_LOCAL" = false ]; then
    # Check host is reachable
    if ! ssh -o ConnectTimeout=5 "$HOST" true 2>/dev/null; then
        echo "Error: Cannot connect to $HOST"
        exit 1
    fi
fi

# Check for existing session
if [ "$IS_LOCAL" = true ]; then
    if tmux has-session -t "$SESSION" 2>/dev/null; then
        echo "Session '$SESSION' already exists locally."
        echo "Use 'muppet-attach' to connect, or kill it first:"
        echo "  tmux kill-session -t $SESSION"
        exit 1
    fi
else
    if ssh -o ConnectTimeout=5 "$HOST" "tmux has-session -t $SESSION 2>/dev/null"; then
        echo "Session '$SESSION' already exists on $HOST."
        echo "Use 'muppet-attach' to connect, or kill it first:"
        echo "  ssh $HOST 'tmux kill-session -t $SESSION'"
        exit 1
    fi
fi

echo "=== Launching muppet: $SESSION ==="
echo "  Host: $HOST"
echo "  Workdir: $WORKDIR"
echo "  Prompt: $PROMPT_FILE"
echo ""

if [ "$IS_LOCAL" = true ]; then
    # Local launch
    echo "[1/3] Creating tmux session '$SESSION'..."
    RESOLVED_WORKDIR="${WORKDIR/#\~/$HOME}"
    tmux new-session -d -s "$SESSION" -x 200 -y 50 "cd $RESOLVED_WORKDIR && exec claude --dangerously-skip-permissions"

    echo "[2/3] Waiting for Claude Code to start..."
    for i in $(seq 1 30); do
        if tmux capture-pane -t "$SESSION" -p 2>/dev/null | grep -q "Claude Code"; then
            break
        fi
        sleep 1
    done
    sleep 3

    echo "[3/3] Sending prompt..."
    tmux send-keys -t "$SESSION" "$(cat "$PROMPT_FILE")" Enter
    # Claude Code TUI needs a second Enter to submit pasted text.
    # Wait long enough for the paste to fully render before submitting.
    sleep 5
    tmux send-keys -t "$SESSION" Enter

    echo ""
    echo "=== Muppet '$SESSION' is running locally ==="
    echo ""
    echo "Connect with:  muppet-attach local"
    echo "   or:         tmux attach -t $SESSION"
    echo "Check status:  tmux capture-pane -t $SESSION -p | tail -20"
    echo ""
else
    # Remote launch
    echo "[1/4] Copying prompt to $HOST..."
    scp -q "$PROMPT_FILE" "$HOST:/tmp/muppet-prompt-${NAME}.txt"

    echo "[2/4] Creating tmux session '$SESSION'..."
    ssh "$HOST" "tmux new-session -d -s $SESSION -x 200 -y 50 \"export PATH=\\\"\\\$HOME/.local/bin:\\\$PATH\\\" && cd $WORKDIR && exec claude --dangerously-skip-permissions\""

    echo "[3/4] Waiting for Claude Code to start..."
    for i in $(seq 1 30); do
        if ssh -o ConnectTimeout=5 "$HOST" "tmux capture-pane -t $SESSION -p 2>/dev/null" | grep -q "Claude Code"; then
            break
        fi
        sleep 1
    done
    sleep 3

    echo "[4/4] Sending prompt..."
    ssh "$HOST" "tmux send-keys -t $SESSION \"\$(cat /tmp/muppet-prompt-${NAME}.txt)\" Enter"

    sleep 2
    ssh "$HOST" "tmux send-keys -t $SESSION Enter"

    echo ""
    echo "=== Muppet '$SESSION' is running on $HOST ==="
    echo ""
    echo "Connect with:  muppet-attach"
    echo "Check status:  ssh $HOST 'tmux capture-pane -t $SESSION -p | tail -20'"
    echo ""
fi
